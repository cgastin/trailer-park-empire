# Terraform state — contains sensitive values (SCRYPT signer key), never commit
*.tfstate
*.tfstate.backup
.terraform/
tfplan

# Actual tfvars contain secrets (billing account ID)
*.tfvars
!terraform.tfvars.example

# .terraform.lock.hcl should be committed for reproducible provider versions
# (it contains no secrets — remove this line if you want to commit it)
.terraform.lock.hcl
